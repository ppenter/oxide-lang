#!/usr/bin/env bash
# ox — Oxide Project Manager
# Usage:
#   ox init [name]       create a new Oxide project
#   ox run [file]        run an Oxide file (or entry from oxide.config.json)
#   ox dev [file]        run with hot-module reload (watches .ox/.oxx files)
#   ox build [file]      compile to native binary via LLVM IR + clang
#   ox test              run tests (looks for tests/ directory)
#   ox version           print the Oxide toolchain version
#
# Examples:
#   ox init my-api       scaffold a new project called my-api
#   ox run               run this project's entry point
#   ox run server.ox     run a specific file
#   ox dev               start dev server with HMR on port 35729
#   ox build             build a native binary from this project

set -e

OXIDE_VERSION="0.1.0"

# Locate oxc relative to this script (they're in the same directory)
OX_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OXC="${OX_DIR}/oxc"

if [ ! -x "${OXC}" ]; then
  echo "ox: error: oxc not found at ${OXC}" >&2
  echo "    Run 'make' in the Oxide source directory first." >&2
  exit 1
fi

# ─ Helpers ───────────────────────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
Oxide ${OXIDE_VERSION} — Project Manager

USAGE:
  ox <command> [options]

COMMANDS:
  init [name]              Create a new Oxide project (scaffolds files & config)
  run  [--port N] [file]   Run an Oxide program (reads entry & port from oxide.config.json)
  dev  [--port N] [file]   Run with hot-module reload — watches .ox/.oxx files and
                           reloads the browser automatically on every save
  build [file.ox]          Compile to a native binary (requires clang on PATH)
  test                     Run the test suite in tests/
  version                  Show Oxide toolchain version
  help                     Show this help message

OPTIONS (run / dev):
  --port N, -p N     Override the server port (sets OX_PORT env var; default from
                     oxide.config.json "port" field, then falls back to program default)
  --hmr-port N       Port for the HMR relay server (default: 35729)

EXAMPLES:
  ox init my-api
  cd my-api && ox dev
  ox dev --port 4000
  ox run examples/hello.ox
  ox run --port 4000
  OX_PORT=8080 ox run server.ox
  ox build server.ox -o server

EOF
}

read_config_entry() {
  local key="$1"
  local file="$2"
  if [ ! -f "$file" ]; then echo ""; return; fi
  grep "\"${key}\"" "$file" | head -1 | sed 's/.*"'"${key}"'"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/'
}

# ─ Commands ───────────────────────────────────────────────────────────────────────────────

cmd_version() {
  echo "Oxide ${OXIDE_VERSION}"
  echo "oxc:  ${OXC}"
}

cmd_init() {
  local name="${1:-my-oxide-app}"

  if [ -d "$name" ]; then
    echo "ox init: directory '${name}' already exists" >&2
    exit 1
  fi

  echo "Scaffolding new Oxide project: ${name}"
  mkdir -p "${name}/src"

  cat > "${name}/oxide.config.json" <<CONFIGEOF
{
  "name": "${name}",
  "version": "0.1.0",
  "description": "",
  "entry": "main.ox",
  "author": "",
  "license": "MIT",
  "paths": {
    "@/": "./src/"
  },
  "dependencies": {},
  "devDependencies": {},
  "scripts": {
    "start": "ox run",
    "test":  "ox test"
  }
}
CONFIGEOF

  cat > "${name}/main.ox" <<MAINEOF
// main.ox — ${name} entry point
// Generated by: ox init ${name}

fn greet(name: string) -> void {
    print("Hello from " + name + "!");
}

let appName: string = "${name}";
greet(appName);
print("Oxide ${OXIDE_VERSION} — ready.");
MAINEOF

  cat > "${name}/.gitignore" <<GITEOF
build/
*.o
*.ll
GITEOF

  echo ""
  echo "  Created ${name}/oxide.config.json"
  echo "  Created ${name}/main.ox"
  echo ""
  echo "  Next steps:"
  echo "    cd ${name}"
  echo "    ox run"
}

cmd_run() {
  local file=""
  local port_override=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --port|-p)
        if [ -z "$2" ] || ! echo "$2" | grep -qE '^[0-9]+$'; then
          echo "ox run: --port requires a numeric argument" >&2
          exit 1
        fi
        port_override="$2"
        shift 2
        ;;
      -*)
        echo "ox run: unknown flag '$1'" >&2
        exit 1
        ;;
      *)
        file="$1"
        shift
        ;;
    esac
  done

  if [ -z "$file" ]; then
    if [ -f "oxide.config.json" ]; then
      file="$(read_config_entry "entry" "oxide.config.json")"
      if [ -z "$file" ]; then
        echo "ox run: no 'entry' found in oxide.config.json" >&2
        exit 1
      fi
      if [ -z "$port_override" ]; then
        local cfg_port
        cfg_port="$(read_config_entry "port" "oxide.config.json")"
        if [ -n "$cfg_port" ] && echo "$cfg_port" | grep -qE '^[0-9]+$'; then
          port_override="$cfg_port"
        fi
      fi
    else
      echo "ox run: no file specified and no oxide.config.json found" >&2
      echo "        Usage: ox run [--port PORT] <file.ox>" >&2
      exit 1
    fi
  fi

  if [ ! -f "$file" ]; then
    echo "ox run: file not found: $file" >&2
    exit 1
  fi

  if [ -n "$port_override" ]; then
    export OX_PORT="$port_override"
  fi

  exec "${OXC}" "$file"
}

cmd_build() {
  local file="$1"
  shift || true
  local outname="${1:--o}"
  local outfile=""

  local extra_args=()
  while [ $# -gt 0 ]; do
    case "$1" in
      -o) outfile="$2"; shift 2 ;;
      *)  extra_args+=("$1"); shift ;;
    esac
  done

  if [ -z "$file" ]; then
    if [ -f "oxide.config.json" ]; then
      file="$(read_config_entry "entry" "oxide.config.json")"
    fi
    if [ -z "$file" ]; then
      echo "ox build: no file specified and no oxide.config.json found" >&2
      exit 1
    fi
  fi

  if [ -z "$outfile" ]; then
    outfile="${file%.ox}"
    outfile="${outfile##*/}"
  fi

  local llfile="/tmp/${outfile}.ll"

  echo "ox build: compiling ${file} → ${outfile}"

  "${OXC}" "${file}" --emit -o "${llfile}"

  if command -v clang &>/dev/null; then
    clang "${llfile}" -o "${outfile}"
    echo "ox build: binary written to ./${outfile}"
  else
    echo "ox build: clang not found — IR written to ${llfile}"
    echo "          Install clang and run: clang ${llfile} -o ${outfile}"
  fi
}

cmd_test() {
  local testDir="tests"
  if [ ! -d "$testDir" ]; then
    echo "ox test: no tests/ directory found" >&2
    exit 1
  fi

  local passed=0
  local failed=0
  echo "Running Oxide tests in ${testDir}/"

  for testfile in "${testDir}"/*.ox; do
    [ -f "$testfile" ] || continue
    if "${OXC}" "${testfile}" > /dev/null 2>&1; then
      echo "  [PASS] ${testfile}"
      ((passed++)) || true
    else
      echo "  [FAIL] ${testfile}"
      "${OXC}" "${testfile}" 2>&1 | sed 's/^/         /'
      ((failed++)) || true
    fi
  done

  echo ""
  echo "Results: ${passed} passed, ${failed} failed"
  [ "$failed" -eq 0 ]
}

# ─ Dispatch ───────────────────────────────────────────────────────────────────────────────

case "${1:-}" in
  init)    shift; cmd_init "$@" ;;
  run)     shift; cmd_run "$@" ;;
  build)   shift; cmd_build "$@" ;;
  test)    shift; cmd_test "$@" ;;
  version) cmd_version ;;
  help|--help|-h) usage ;;
  "")      usage; exit 1 ;;
  *)
    echo "ox: unknown command '${1}'" >&2
    echo "    Run 'ox help' for usage." >&2
    exit 1
    ;;
esac
